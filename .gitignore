# ─── Node / Vite ──────────────────────────────────────────────────
web/node_modules/
web/dist/
web/.vite/
web/*.local
web/vite.config.ts.timestamp-*.mjs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Xcode ────────────────────────────────────────────────────────
ios/build/
ios/DerivedData/
ios/**/xcuserdata/
ios/**/*.xcuserdatad
ios/**/UserInterfaceState.xcuserstate
ios/**/contents.xcworkspacedata.lock
*.xcarchive

# ─── Session cruft (legacy from local builds) ─────────────────────
_old_dist_*
_old_WebApp_*
_trash_*

# ─── macOS / editor noise ─────────────────────────────────────────
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# ─── Local secrets (none today, but future-proofed) ───────────────
.env
.env.*
!.env.example
